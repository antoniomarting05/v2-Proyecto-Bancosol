                        <th>Entidad</th>
                        <th>Área asignada</th>
                        <th>Teléfono</th>
                        <th>Correo electrónico</th>
                        <th>Tiendas</th>
                        <th>Usuario</th>
                    </tr>
                    </thead>

                    <tbody>
                    <% if (listaCoordinadores != null && !listaCoordinadores.isEmpty()) { %>
                    <% for (Usuario coordinador : listaCoordinadores) { %>
                    <tr>
                        <td>
                            <div class="campanya-row-actions">
