            u.setId(entity.getCoordinador().getId());
            u.setNombre(entity.getCoordinador().getNombre());
            dto.setCoordinador(u);
        }

        if (entity.getContactos() != null) {
            dto.setContactos(entity.getContactos().stream().map(c -> {
