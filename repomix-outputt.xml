/* ============================
   Layout general de cadenas
   ============================ */

.cadena-list-wrapper {
    max-width: 1100px;
    margin: 0 auto;
}

.cadena-form-wrapper {
    max-width: 900px;
    margin: 0 auto;
}

.cadena-list-header,
.cadena-form-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.cadena-list-header h2,
.cadena-form-header h2 {
    font-size: 1.4rem;
    margin: 0;
    color: var(--text-dark);
}

.cadena-list-header p,
.cadena-form-header p {
    margin: 6px 0 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
}


/* ============================
   Acciones superiores
   ============================ */

.cadena-header-actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 12px;
    margin-top: 18px;
}

.cadena-create-btn {
    background-color: var(--primary-blue);
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s;
    text-decoration: none;

    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.cadena-create-btn:hover {
    background-color: var(--accent-blue);
    text-decoration: none;
}

.cadena-create-icon {
    font-size: 20px;
    line-height: 1;
}


/* ============================
   Tabla de cadenas
   ============================ */

.cadena-table-card {
    padding: 0;
    overflow: hidden;
}

.cadena-table {
    table-layout: fixed;
}

.cadena-table th:nth-child(1),
.cadena-table td:nth-child(1) {
    width: 52%;
}

.cadena-table th:nth-child(2),
.cadena-table td:nth-child(2) {
    width: 18%;
}

.cadena-table th:nth-child(3),
.cadena-table td:nth-child(3) {
    width: 30%;
}

.cadena-row-actions {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: auto;
}


/* ============================
   Botones de acciones de fila
   ============================ */

.cadena-edit-btn,
.cadena-delete-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;

    padding: 8px 12px;
    border-radius: 10px;

    background-color: #eaf2ff;
    color: #123c69;
    font-weight: 700;
    font-size: 14px;

    text-decoration: none;
    border: 1px solid #c7dbf5;

    transition:
            background-color 0.2s ease,
            transform 0.2s ease,
            box-shadow 0.2s ease;
}

.cadena-edit-btn:hover,
.cadena-delete-check:hover {
    background-color: #d9eaff;
    color: #0b2d52;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(18, 60, 105, 0.15);
